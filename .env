# Tiempo de expiración del token de acceso
# Formato: '15m' (15 minutos), '1h' (1 hora), '7d' (7 días), '24h' (24 horas), '30d' (30 días)
JWT_EXPIRES_IN=24h

# Tiempo de expiración del refresh token (para renovar el access token)
